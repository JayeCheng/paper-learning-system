{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/JayeCheng/paper-learning-system/schemas/knowledge_graph.schema.json",
  "title": "KnowledgeGraph",
  "type": "object",
  "required": ["nodes", "edges"],
  "additionalProperties": false,
  "properties": {
    "public_json_version": {
      "type": "string",
      "default": "0.1"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "type"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["paper", "concept", "method", "benchmark", "question", "author", "venue"]
          },
          "topics": {
            "type": "array",
            "items": { "type": "string" },
            "default": []
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "target", "relation"],
        "additionalProperties": false,
        "properties": {
          "source": { "type": "string" },
          "target": { "type": "string" },
          "relation": {
            "type": "string",
            "enum": ["introduces", "extends", "contrasts", "uses", "evaluates", "motivates", "related_to"]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "default": 0.5
          }
        }
      }
    }
  }
}
