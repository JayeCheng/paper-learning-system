{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/JayeCheng/paper-learning-system/schemas/paper.schema.json",
  "title": "Paper",
  "type": "object",
  "required": ["id", "title", "source", "topics", "url"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "title_zh": { "type": ["string", "null"] },
    "field": { "type": ["string", "null"] },
    "authors": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "institutions": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "abstract": { "type": "string" },
    "source": {
      "type": "string",
      "enum": ["arxiv", "openreview", "biorxiv", "semantic_scholar", "github", "manual"]
    },
    "source_type": {
      "type": ["string", "null"],
      "enum": ["recent_24h", "recent_7d", "classic", null]
    },
    "source_url": {
      "type": ["string", "null"]
    },
    "topics": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "categories": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "url": { "type": "string" },
    "pdf_url": { "type": ["string", "null"] },
    "code_url": { "type": ["string", "null"] },
    "project_url": { "type": ["string", "null"] },
    "published_date": {
      "type": ["string", "null"],
      "format": "date"
    },
    "published_at": {
      "type": ["string", "null"],
      "format": "date"
    },
    "citation_count": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "venue": { "type": ["string", "null"] },
    "difficulty": {
      "type": ["string", "null"],
      "enum": ["low", "medium", "high", null]
    },
    "why_recommended": { "type": ["string", "null"] },
    "recommendation_level": {
      "type": ["string", "null"],
      "enum": ["S", "A", "B", "C", null]
    },
    "reading_advice": {
      "type": ["string", "null"],
      "enum": ["deep_read", "quick_read", "save_for_later", "abstract_only", null]
    },
    "classic_status": { "type": ["string", "null"] },
    "selected_for_s_level": { "type": "boolean" },
    "score": { "type": ["number", "null"] },
    "identifiers": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "scores": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    },
    "reading_status": {
      "type": "string",
      "enum": ["backlog", "queued", "skimmed", "deep_read", "archived", "skipped"]
    }
  }
}
