{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/JayeCheng/paper-learning-system/schemas/latest.schema.json",
  "title": "LatestPublicEntry",
  "type": "object",
  "required": ["public_json_version", "frontend_entry", "latest"],
  "additionalProperties": false,
  "properties": {
    "public_json_version": { "type": "string", "default": "0.2" },
    "frontend_entry": { "type": "string" },
    "latest": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "date": { "type": ["string", "null"] },
        "generated_at": { "type": ["string", "null"] },
        "markdown_path": { "type": ["string", "null"] },
        "json_path": { "type": ["string", "null"] },
        "paper_count": { "type": "integer", "minimum": 0 },
        "s_level_paper_id": { "type": ["string", "null"] },
        "status": { "type": "string" }
      }
    }
  }
}
