{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/JayeCheng/paper-learning-system/schemas/daily_report.schema.json",
  "title": "DailyReport",
  "type": "object",
  "required": ["date", "generated_at", "papers", "summary"],
  "additionalProperties": false,
  "properties": {
    "date": { "type": "string", "format": "date" },
    "generated_at": { "type": "string", "format": "date-time" },
    "summary": { "type": "string" },
    "learning_route_position": { "type": ["string", "null"] },
    "source_mode_summary": {
      "type": "object",
      "additionalProperties": { "type": "integer" },
      "default": {}
    },
    "s_level_paper_id": { "type": ["string", "null"] },
    "public_json_version": {
      "type": "string",
      "default": "0.1"
    },
    "generated_paths": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "default": {}
    },
    "frontend_entry": { "type": "string" },
    "papers": {
      "type": "array",
      "items": { "$ref": "paper.schema.json" }
    },
    "s_level_candidate_ids": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "knowledge_graph_delta": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "next_actions": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    }
  }
}
