{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/JayeCheng/paper-learning-system/schemas/reading_status.schema.json",
  "title": "PublicReadingStatus",
  "type": "object",
  "required": ["public_json_version", "updated_at", "statuses"],
  "additionalProperties": false,
  "properties": {
    "public_json_version": { "type": "string", "default": "0.3" },
    "updated_at": { "type": "string" },
    "statuses": {
      "type": "array",
      "items": { "$ref": "reading_status_entry.schema.json" },
      "default": []
    }
  }
}
